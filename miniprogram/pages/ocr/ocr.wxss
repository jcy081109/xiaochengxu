.ocr-page {
  background: linear-gradient(180deg, #f3f6f8 0%, #f6f7f4 36%);
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.mini-action {
  flex-shrink: 0;
  min-width: 112rpx;
  height: 62rpx;
  margin: 0;
  padding: 0 20rpx;
  border: none;
  border-radius: 14rpx;
  background: var(--primary-soft);
  color: var(--primary-color);
  font-size: 25rpx;
  font-weight: 700;
  line-height: 62rpx;
}

.preview-image {
  width: 100%;
  height: 430rpx;
  margin-top: 24rpx;
  border-radius: 18rpx;
  background: #e8ece8;
}

.empty-upload {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 360rpx;
  margin-top: 24rpx;
  border: 2rpx dashed #cbd6ce;
  border-radius: 18rpx;
  background: #f8faf8;
}

.empty-upload-title {
  color: var(--text-color);
  font-size: 31rpx;
  font-weight: 800;
}

.empty-upload-desc {
  margin-top: 12rpx;
  color: var(--muted-color);
  font-size: 25rpx;
}

.status-panel {
  margin-top: 22rpx;
}

.error-panel {
  border-color: #efb6b6;
  background: var(--danger-soft);
}

.status-tip {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: var(--muted-color);
}

.ocr-preview {
  display: block;
  max-height: 560rpx;
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #f7f8f6;
  color: var(--text-color);
  font-size: 28rpx;
  line-height: 1.75;
  white-space: pre-wrap;
}

.result-actions {
  margin-top: 6rpx;
}
