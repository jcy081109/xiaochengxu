.form-page {
  background: linear-gradient(180deg, #f7faf8 0%, #f6f7f4 36%);
}

.form-panel {
  padding-top: 24rpx;
}

.form-hint {
  padding: 20rpx;
  border-radius: 16rpx;
  background: var(--accent-soft);
}

.hint-title {
  display: block;
  color: var(--accent-color);
  font-size: 26rpx;
  font-weight: 800;
}

.hint-desc {
  display: block;
  margin-top: 8rpx;
  color: #52677f;
  font-size: 24rpx;
  line-height: 1.55;
}

.field {
  margin-top: 28rpx;
}

.preview-image {
  width: 100%;
  height: 320rpx;
  margin-top: 24rpx;
  border-radius: 18rpx;
  background: #e8ece8;
}
