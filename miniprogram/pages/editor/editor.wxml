<view class="page">
  <view class="panel">
    <text class="section-title">{{isEdit ? 'Edit Note' : 'Create Note'}}</text>
    <text class="section-desc">
      Review the OCR result, fix mistakes, add a title and category, then save it as a structured note.
    </text>

    <block wx:if="{{imagePath}}">
      <image class="preview-image" src="{{imagePath}}" mode="aspectFit"></image>
    </block>

    <view class="field">
      <text class="field-label">Title</text>
      <input
        class="input"
        placeholder="Example: Operating System Lecture Notes"
        value="{{title}}"
        bindinput="onTitleInput"
      />
    </view>

    <view class="field">
      <text class="field-label">Category</text>
      <picker mode="selector" range="{{categoryOptions}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="picker-box">{{categoryOptions[categoryIndex]}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="field-label">Content</text>
      <textarea
        class="textarea"
        placeholder="OCR text will be filled in automatically, but you can also type or revise it here."
        value="{{content}}"
        bindinput="onContentInput"
      />
    </view>

    <button class="primary-btn" bindtap="saveNote">{{isEdit ? 'Save Changes' : 'Save Note'}}</button>
  </view>
</view>
