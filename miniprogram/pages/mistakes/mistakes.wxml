<view class="page list-page">
  <view class="page-header">
    <text class="page-kicker">错题本</text>
    <text class="page-title">记录问题，跟踪掌握状态</text>
    <text class="page-desc">先选择录入方式，再按科目和状态复习错题。</text>
  </view>

  <view class="create-grid">
    <view class="panel create-card primary-create" bindtap="importFromRecords">
      <text class="create-tag">推荐</text>
      <text class="create-title">从记录创建</text>
      <text class="create-desc">从已保存笔记或 OCR 识别记录导入题目、答案、解析。</text>
    </view>
    <view class="panel create-card" bindtap="createFromPhoto">
      <text class="create-tag blue-tag">拍照</text>
      <text class="create-title">拍照创建</text>
      <text class="create-desc">分别拍照识别题目、答案或解析，再手动校对。</text>
    </view>
    <view class="panel create-card" bindtap="createMistake">
      <text class="create-tag plain-tag">手动</text>
      <text class="create-title">手动创建</text>
      <text class="create-desc">直接输入完整错题内容，适合少量补录。</text>
    </view>
  </view>

  <view class="panel toolbar-panel">
    <input
      class="input search-input"
      placeholder="搜索题目、答案、解析或标签"
      value="{{keyword}}"
      bindinput="onKeywordInput"
    />

    <view class="toolbar-row">
      <picker class="toolbar-picker" mode="selector" range="{{subjectOptions}}" value="{{subjectIndex}}" bindchange="onSubjectChange">
        <view class="picker-box compact-picker">{{subjectOptions[subjectIndex]}}</view>
      </picker>
      <picker class="toolbar-picker" mode="selector" range="{{masteredOptions}}" value="{{masteredIndex}}" bindchange="onMasteredChange">
        <view class="picker-box compact-picker">{{masteredOptions[masteredIndex]}}</view>
      </picker>
      <button class="text-btn" bindtap="clearFilters">清空</button>
    </view>
  </view>

  <view class="list-summary">
    <text class="meta-text">当前显示 {{mistakes.length}} 条错题</text>
  </view>

  <block wx:if="{{mistakes.length}}">
    <view class="panel mistake-card" wx:for="{{mistakes}}" wx:key="id">
      <view class="card-body" data-id="{{item.id}}" bindtap="openDetail">
        <view class="mistake-header">
          <text class="mistake-subject">{{item.subject}}</text>
          <text class="mistake-status {{item.mastered ? 'status-done' : 'status-open'}}">{{item.masteredLabel}}</text>
        </view>
        <text class="mistake-question">{{item.preview}}</text>
        <text class="mistake-meta">{{item.tagsText}} | {{item.displayTime}}</text>
      </view>
      <view class="card-actions">
        <button class="text-btn" data-id="{{item.id}}" bindtap="toggleMastered">
          {{item.mastered ? '设为未掌握' : '设为已掌握'}}
        </button>
        <button class="text-btn delete-text" data-id="{{item.id}}" bindtap="deleteMistake">删除</button>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="panel empty-panel">
      <text class="empty-text">没有找到匹配的错题</text>
    </view>
  </block>
</view>
