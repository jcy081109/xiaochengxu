<view class="page">
  <view class="panel">
    <text class="section-title">错题本</text>
    <text class="section-desc">记录错题、答案、解析和标签，集中复习未掌握内容。</text>

    <view class="filter-group">
      <text class="field-label">关键词</text>
      <input
        class="input"
        placeholder="搜索题目、答案、解析或标签"
        value="{{keyword}}"
        bindinput="onKeywordInput"
      />
    </view>

    <view class="filter-group">
      <text class="field-label">科目</text>
      <picker mode="selector" range="{{subjectOptions}}" value="{{subjectIndex}}" bindchange="onSubjectChange">
        <view class="picker-box">{{subjectOptions[subjectIndex]}}</view>
      </picker>
    </view>

    <view class="filter-group">
      <text class="field-label">掌握状态</text>
      <picker mode="selector" range="{{masteredOptions}}" value="{{masteredIndex}}" bindchange="onMasteredChange">
        <view class="picker-box">{{masteredOptions[masteredIndex]}}</view>
      </picker>
    </view>

    <button class="primary-btn" bindtap="createMistake">新增错题</button>
    <button class="secondary-btn" bindtap="clearFilters">清空筛选</button>
  </view>

  <block wx:if="{{mistakes.length}}">
    <view class="panel mistake-card" wx:for="{{mistakes}}" wx:key="id">
      <view data-id="{{item.id}}" bindtap="openDetail">
        <view class="mistake-header">
          <text class="mistake-subject">{{item.subject}}</text>
          <text class="mistake-status {{item.mastered ? 'status-done' : 'status-open'}}">{{item.masteredLabel}}</text>
        </view>
        <text class="mistake-question">{{item.preview}}</text>
        <text class="mistake-meta">{{item.tagsText}} | {{item.displayTime}}</text>
      </view>
      <button class="secondary-btn" data-id="{{item.id}}" bindtap="toggleMastered">
        {{item.mastered ? '标记为未掌握' : '标记为已掌握'}}
      </button>
      <button class="delete-btn" data-id="{{item.id}}" bindtap="deleteMistake">删除</button>
    </view>
  </block>

  <block wx:else>
    <view class="panel empty-panel">
      <text class="empty-text">没有找到匹配的错题</text>
    </view>
  </block>
</view>
