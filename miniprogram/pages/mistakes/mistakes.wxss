.create-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
}

.create-card {
  min-height: 174rpx;
  padding: 24rpx;
}

.primary-create {
  border-color: #bfd8cd;
  background: linear-gradient(180deg, #ffffff 0%, #eef7f2 100%);
}

.create-tag {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: var(--primary-soft);
  color: var(--primary-color);
  font-size: 21rpx;
  font-weight: 800;
}

.blue-tag {
  background: var(--accent-soft);
  color: var(--accent-color);
}

.plain-tag {
  background: #eef0ee;
  color: #5e665f;
}

.create-title {
  display: block;
  margin-top: 14rpx;
  font-size: 31rpx;
  line-height: 1.3;
  font-weight: 800;
}

.create-desc {
  display: block;
  margin-top: 8rpx;
  color: var(--muted-color);
  font-size: 24rpx;
  line-height: 1.5;
}

.toolbar-panel {
  margin-top: 22rpx;
}

.search-input {
  background: #f8faf8;
}

.toolbar-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
}

.toolbar-picker {
  flex: 1;
}

.compact-picker {
  height: 72rpx;
  min-height: 72rpx;
  padding: 18rpx 18rpx;
  line-height: 34rpx;
}

.list-summary {
  padding: 22rpx 6rpx 0;
}

.mistake-card,
.empty-panel {
  margin-top: 18rpx;
}

.mistake-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.mistake-subject {
  font-size: 27rpx;
  font-weight: 800;
  color: var(--primary-color);
}

.mistake-status {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.status-done {
  background: var(--primary-soft);
  color: var(--primary-color);
}

.status-open {
  background: var(--warning-soft);
  color: var(--warning-color);
}

.mistake-question {
  display: block;
  margin-top: 18rpx;
  font-size: 31rpx;
  line-height: 1.55;
  font-weight: 800;
}

.mistake-meta {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--muted-color);
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 30rpx;
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf0ec;
}

.delete-text {
  color: var(--danger-color);
}
