.filter-group {
  margin-top: 24rpx;
}

.filter-panel {
  margin-top: 24rpx;
}

.filter-title {
  font-size: 30rpx;
  margin-bottom: 0;
}

.mistake-card,
.empty-panel {
  margin-top: 24rpx;
}

.mistake-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.mistake-subject {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.mistake-status {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status-done {
  background: #e1efe7;
  color: var(--primary-color);
}

.status-open {
  background: #fff0d7;
  color: #9a6425;
}

.mistake-question {
  display: block;
  margin-top: 18rpx;
  font-size: 31rpx;
  line-height: 1.6;
  font-weight: 700;
}

.mistake-meta {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--muted-color);
}

.delete-btn {
  width: 100%;
  margin-top: 18rpx;
  border: none;
  border-radius: 999rpx;
  background: #f7dede;
  color: var(--danger-color);
  font-size: 28rpx;
}
