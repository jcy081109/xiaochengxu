<view class="page detail-page">
  <block wx:if="{{note}}">
    <view class="panel detail-panel">
      <text class="note-title">{{note.title}}</text>
      <view class="detail-meta-row">
        <text class="pill">{{note.category}}</text>
        <text class="note-meta">{{displayTime}}</text>
      </view>

      <block wx:if="{{note.imagePath}}">
        <image class="preview-image" src="{{note.imagePath}}" mode="aspectFit"></image>
      </block>

      <text class="note-content">{{note.content}}</text>
      <button class="primary-btn" bindtap="editNote">编辑笔记</button>
      <button class="secondary-btn danger-btn" bindtap="deleteNote">删除笔记</button>
    </view>
  </block>

  <block wx:else>
    <view class="panel">
      <text class="empty-text">未找到笔记</text>
    </view>
  </block>
</view>
