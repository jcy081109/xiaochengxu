.list-page {
  background: #f6f7f4;
}

.toolbar-panel {
  padding-bottom: 24rpx;
}

.search-input {
  background: #f8faf8;
}

.toolbar-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
}

.toolbar-picker {
  flex: 1;
}

.compact-picker {
  height: 72rpx;
  min-height: 72rpx;
  padding: 18rpx 22rpx;
  line-height: 34rpx;
}

.create-btn {
  margin-top: 18rpx;
}

.list-summary {
  padding: 22rpx 6rpx 0;
}

.note-card {
  margin-top: 18rpx;
  padding-bottom: 18rpx;
}

.card-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.note-title {
  display: block;
  margin-top: 18rpx;
  font-size: 33rpx;
  line-height: 1.35;
  font-weight: 800;
}

.note-meta {
  flex-shrink: 0;
  font-size: 23rpx;
  color: var(--muted-color);
}

.note-content {
  display: block;
  margin-top: 12rpx;
  font-size: 27rpx;
  line-height: 1.65;
  color: var(--muted-color);
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 30rpx;
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf0ec;
}

.delete-text {
  color: var(--danger-color);
}

.empty-panel {
  margin-top: 18rpx;
}
