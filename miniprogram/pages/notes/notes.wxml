<view class="page">
  <view class="panel">
    <text class="section-title">学习笔记</text>
    <text class="section-desc">搜索、筛选、查看、编辑和删除本地学习笔记。</text>

    <view class="filter-group">
      <text class="field-label">关键词</text>
      <input
        class="input"
        placeholder="按标题或内容搜索"
        value="{{keyword}}"
        bindinput="onKeywordInput"
      />
    </view>

    <view class="filter-group">
      <text class="field-label">分类</text>
      <picker mode="selector" range="{{categoryOptions}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="picker-box">{{categoryOptions[categoryIndex]}}</view>
      </picker>
    </view>

    <button class="primary-btn" bindtap="createManualNote">新建空白笔记</button>
    <button class="secondary-btn" bindtap="clearFilters">清空筛选</button>
  </view>

  <block wx:if="{{notes.length}}">
    <view class="panel note-card" wx:for="{{notes}}" wx:key="id">
      <view data-id="{{item.id}}" bindtap="openDetail">
        <text class="note-title">{{item.title}}</text>
        <text class="note-meta">{{item.category}} | {{item.displayTime}}</text>
        <text class="note-content">{{item.preview}}</text>
      </view>
      <button class="delete-btn" data-id="{{item.id}}" bindtap="deleteNote">删除</button>
    </view>
  </block>

  <block wx:else>
    <view class="panel">
      <text class="empty-text">没有找到匹配的笔记</text>
    </view>
  </block>
</view>
