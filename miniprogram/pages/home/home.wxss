.home-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  background:
    radial-gradient(circle at top left, rgba(217, 152, 79, 0.18), transparent 36%),
    linear-gradient(180deg, #f3ead9 0%, #f7f4ee 42%, #f7f4ee 100%);
}

.hero {
  margin-top: 16rpx;
}

.hero-eyebrow {
  display: inline-block;
  margin-bottom: 18rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(31, 92, 74, 0.1);
  color: var(--primary-color);
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.hero-title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 52rpx;
  line-height: 1.2;
  font-weight: 700;
}

.module-panel {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.waiting-panel {
  background: linear-gradient(180deg, #fffdf8 0%, #f7f0e1 100%);
}
