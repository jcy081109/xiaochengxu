.detail-page {
  background: #f6f7f4;
}

.detail-panel {
  margin-top: 12rpx;
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-subject {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--primary-color);
}

.detail-status {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.status-done {
  background: var(--primary-soft);
  color: var(--primary-color);
}

.status-open {
  background: var(--warning-soft);
  color: var(--warning-color);
}

.detail-meta {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--muted-color);
}

.section-block {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid #e8ede8;
  border-radius: 16rpx;
  background: #f8faf8;
}

.block-title {
  display: block;
  font-size: 25rpx;
  font-weight: 800;
  color: var(--primary-color);
}

.block-content {
  display: block;
  margin-top: 12rpx;
  font-size: 29rpx;
  line-height: 1.8;
  white-space: pre-wrap;
}
