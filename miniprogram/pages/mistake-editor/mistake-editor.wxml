<view class="page form-page">
  <view class="page-header">
    <text class="page-kicker">错题录入</text>
    <text class="page-title">{{isEdit ? '编辑错题' : modeTitle}}</text>
    <text class="page-desc">{{isEdit ? '修改题目、答案、解析、标签和掌握状态。' : modeDesc}}</text>
  </view>

  <view class="panel mode-panel" wx:if="{{!isEdit}}">
    <text class="mode-name">{{modeTitle}}</text>
    <text class="mode-copy">{{modeHelpText}}</text>
  </view>

  <view class="panel form-panel">

    <view class="field">
      <text class="field-label">科目</text>
      <picker mode="selector" range="{{subjectOptions}}" value="{{subjectIndex}}" bindchange="onSubjectChange">
        <view class="picker-box">{{subjectOptions[subjectIndex]}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="field-head">
        <text class="field-label">题目</text>
        <view class="field-tools" wx:if="{{createMode !== 'manual'}}">
        <picker
          wx:if="{{createMode === 'record' && importRecordOptions.length}}"
          mode="selector"
          range="{{importRecordOptions}}"
          range-key="label"
          data-field="question"
          bindchange="onRecordImportChange"
        >
          <view class="field-tool-btn">从记录填入</view>
        </picker>
        <button wx:elif="{{createMode === 'record'}}" class="field-tool-btn" bindtap="showNoRecordsTip">从记录填入</button>
        <button
          wx:if="{{createMode === 'photo'}}"
          class="field-tool-btn"
          data-field="question"
          loading="{{recognizingField === 'question'}}"
          bindtap="recognizeFieldFromEvent"
        >
          拍照识别填入
        </button>
        </view>
      </view>
      <textarea
        class="textarea"
        placeholder="{{createMode === 'record' ? '从记录填入题目，也可以手动修改' : createMode === 'photo' ? '拍照识别题目，也可以手动修改' : '手动输入题目'}}"
        value="{{question}}"
        bindinput="onQuestionInput"
      />
    </view>

    <view class="field">
      <view class="field-head">
        <text class="field-label">答案</text>
        <view class="field-tools" wx:if="{{createMode !== 'manual'}}">
        <picker
          wx:if="{{createMode === 'record' && importRecordOptions.length}}"
          mode="selector"
          range="{{importRecordOptions}}"
          range-key="label"
          data-field="answer"
          bindchange="onRecordImportChange"
        >
          <view class="field-tool-btn">从记录填入</view>
        </picker>
        <button wx:elif="{{createMode === 'record'}}" class="field-tool-btn" bindtap="showNoRecordsTip">从记录填入</button>
        <button
          wx:if="{{createMode === 'photo'}}"
          class="field-tool-btn"
          data-field="answer"
          loading="{{recognizingField === 'answer'}}"
          bindtap="recognizeFieldFromEvent"
        >
          拍照识别填入
        </button>
        </view>
      </view>
      <textarea
        class="textarea compact-textarea"
        placeholder="{{createMode === 'record' ? '从记录填入答案，也可以手动修改' : createMode === 'photo' ? '拍照识别答案，也可以手动修改' : '手动输入答案'}}"
        value="{{answer}}"
        bindinput="onAnswerInput"
      />
    </view>

    <view class="field">
      <view class="field-head">
        <text class="field-label">解析</text>
        <view class="field-tools" wx:if="{{createMode !== 'manual'}}">
        <picker
          wx:if="{{createMode === 'record' && importRecordOptions.length}}"
          mode="selector"
          range="{{importRecordOptions}}"
          range-key="label"
          data-field="analysis"
          bindchange="onRecordImportChange"
        >
          <view class="field-tool-btn">从记录填入</view>
        </picker>
        <button wx:elif="{{createMode === 'record'}}" class="field-tool-btn" bindtap="showNoRecordsTip">从记录填入</button>
        <button
          wx:if="{{createMode === 'photo'}}"
          class="field-tool-btn"
          data-field="analysis"
          loading="{{recognizingField === 'analysis'}}"
          bindtap="recognizeFieldFromEvent"
        >
          拍照识别填入
        </button>
        </view>
      </view>
      <textarea
        class="textarea compact-textarea"
        placeholder="{{createMode === 'record' ? '从记录填入解析，也可以手动修改' : createMode === 'photo' ? '拍照识别解析，也可以手动修改' : '手动输入解析'}}"
        value="{{analysis}}"
        bindinput="onAnalysisInput"
      />
    </view>

    <view class="field">
      <text class="field-label">标签</text>
      <input
        class="input"
        placeholder="用空格或逗号分隔标签"
        value="{{tags}}"
        bindinput="onTagsInput"
      />
    </view>

    <view class="switch-row">
      <text class="field-label switch-label">已掌握</text>
      <switch checked="{{mastered}}" bindchange="onMasteredChange" />
    </view>

    <button class="primary-btn" bindtap="saveMistake">{{isEdit ? '保存修改' : '保存错题'}}</button>
  </view>
</view>
